# KampungKaki — environment template.
# Copy this to .env.local and fill what you have. Everything degrades
# gracefully: missing keys show "unavailable" in the app, they never fake data.
# The start script copies this for you on first run if .env.local is absent.

# ── AI (Ollama) ───────────────────────────────────────────────────────────────
# The AI agents (Pelita/Bekal/Pondok) call a LOCAL Ollama daemon. The model tag
# ":cloud" routes to ollama.com under YOUR signed-in account — so on a new
# machine you must: install Ollama, then run `ollama signin` once.
# In Docker the web container reaches the host daemon via host.docker.internal.
OLLAMA_BASE_URL=http://localhost:11434
KK_AI_MODEL=minimax-m2.5:cloud

# ── Singapore live-data adapters (optional — map layers show "unavailable" without) ──
DATAMALL_ACCOUNT_KEY=
DATAGOV_API_KEY=
ONEMAP_API_KEY=

# ── Local app / realtime bridge (defaults are correct for the bundled compose) ──
PORT=8787
VITE_ENABLE_LIVE_PROVIDER_FETCH=true
DISABLE_HMR=false

# ── Not used by the agents (kept for the older OpenRouter path) ────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# ── Optional future hospital-load adapter. Leave blank unless a real source exists ──
HOSPITAL_LOAD_API_URL=
HOSPITAL_LOAD_API_KEY=
